# Auth
# Generate a unique pepper: openssl rand -base64 32
PASSWORD_PEPPER=change-me-to-a-long-random-pepper-value
COOKIE_SECURE=false

# Database (app Postgres — not SigNoz metastore)
# Compose binds Postgres to 127.0.0.1 only. Do not use these defaults on a shared LAN.
DATABASE_URL=postgres://reservations:reservations@localhost:5432/reservations
POSTGRES_USER=reservations
POSTGRES_PASSWORD=reservations
POSTGRES_DB=reservations

# Garage (S3-compatible)
# After `just garage-init`, replace ACCESS/SECRET with the generated key values.
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_REGION=garage
GARAGE_ACCESS_KEY=GK1234567890abcdef
GARAGE_SECRET_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCDEF
GARAGE_BUCKET=equipment-images
# Generate a unique value with: openssl rand -base64 32
GARAGE_ADMIN_TOKEN=

# OpenTelemetry — gateway collector (host ports avoid SigNoz 4317/4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14317
OTEL_SERVICE_NAME=equipment-reservation-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# Backend
RUST_LOG=info,equipment_reservation=debug
BIND_ADDR=0.0.0.0:3000
FRONTEND_ORIGIN=http://localhost:5173
# Comma-separated origins also work, e.g. http://localhost:5173,http://localhost:8088
# Dedicated Compose proxy network used only by Caddy and backend. Do not widen
# this to a LAN or a shared container network: direct callers could spoof XFF.
TRUSTED_PROXIES=172.30.0.0/24

# SigNoz (Foundry) — set DOCKER_HOST for Podman if needed
# macOS Podman machine example:
# DOCKER_HOST=unix:///Users/$USER/.local/share/containers/podman/machine/podman.sock
SIGNOZ_OTLP_ENDPOINT=host.containers.internal:4317
