{
	auto_https off
	admin off
}

:80 {
	tracing {
		span caddy.request
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 3
		}
		format json
	}

	handle /api/* {
		reverse_proxy backend-proxy:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /health {
		reverse_proxy backend-proxy:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	handle {
		reverse_proxy frontend:5173
	}
}
